POSTGRES_HOST=
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=
DAGSTER_HOME=
DAGSTER_HOST=
DAGSTER_PORT=
ASSEMBLY_LOG_LEVEL=
ASSEMBLY_SERVICE_TOKEN=

# Required when enabling the minio optional bundle.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=

# Required when enabling the grafana optional bundle.
GRAFANA_ADMIN_USER=
GRAFANA_ADMIN_PASSWORD=

# Required when enabling the superset optional bundle.
SUPERSET_SECRET_KEY=

# === LLM backend (pick exactly one; populated by `assembly setup`) ===
# Docker compose only passes these env values through to Dagster containers.
# MiniMax is container-ready because it only needs API env. Codex/Claude
# subscription backends are host-managed/runtime-only today: compose does not
# install codex/claude CLIs, start sidecars, or mount host auth/keychain state.
# A. MiniMax public API (set the key + leave both gates empty)
MINIMAX_API_KEY=
MINIMAX_API_BASE=
# B. OpenAI Codex via ChatGPT subscription (run `codex login` once on host,
#    then set the host-managed runtime gate to "1"; no key needed)
REASONER_RUNTIME_ENABLE_CODEX_OAUTH=
# C. Claude Code via Pro/Max subscription (run `claude /login` once on host,
#    then set the host-managed runtime gate to "1"; no key needed)
REASONER_RUNTIME_ENABLE_CLAUDE_CODE_CLI=
